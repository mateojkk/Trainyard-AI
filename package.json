{
  "name": "trainyard-ai",
  "private": true,
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "dev": "sh -c '(cd apps && backend/.venv/bin/python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 --reload) & (cd apps/frontend && npm run dev)'",
    "dev:backend": "cd apps && backend/.venv/bin/python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 --reload",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "build": "cd apps/frontend && npm run build",
    "lint": "cd apps/frontend && npm run lint"
  }
}
